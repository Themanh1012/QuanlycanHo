<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- QUYỀN TRUY CẬP ẢNH -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- QUYỀN CAMERA -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- QUYỀN GHI FILE (Android 9 trở xuống) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Room"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".auth.RegisterActivity" android:exported="false" />

        <!-- Admin -->
        <activity android:name=".admin.AdminDashboardActivity" android:exported="false" />
        <activity android:name=".admin.ManageUserActivity" android:exported="false" />
        <activity android:name=".admin.ManageApartmentsActivity" android:exported="false" />
        <activity android:name=".admin.AddEditApartmentActivity" android:exported="false" />
        <activity android:name=".admin.AddEditUserActivity" android:exported="false" />
        <activity android:name=".admin.ChangePasswordActivity" android:exported="false" />
        <activity android:name=".admin.FullscreenImageActivity" android:exported="false" />

        <!-- Customer -->
        <activity android:name=".MainActivity" android:exported="false" />

        <!-- Listing -->
        <activity android:name=".listing.ApartmentDetailActivity" android:exported="false" />
        <activity android:name=".listing.AddPostActivity" android:exported="false" />
        <activity android:name=".listing.MotelListActivity" android:exported="false" />
        <activity android:name=".listing.ApartmentListActivity" android:exported="false" />

        <!-- User -->
        <activity android:name=".user.EditProfileActivity" android:exported="false" />
        <activity android:name=".user.HistoryActivity" android:exported="false" />
        <activity android:name=".user.SettingsActivity" android:exported="false" />

    </application>

</manifest>